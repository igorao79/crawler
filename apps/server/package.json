{
  "name": "@lusion-crawler/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "proxy": "tsx src/proxy/cache-proxy.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.0.0",
    "@lusion-crawler/shared": "*",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.0.0",
    "playwright": "^1.50.0",
    "prettier": "^3.8.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
